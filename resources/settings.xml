                <setting id="style" type="string" label="32006" help="32007">
                    <level>0</level>
                    <default>auto</default>
                    <constraints>
                        <options>
                            <option label="32008">auto</option>
                            <option label="32009">rounded</option>
                            <option label="32010">square</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="filter_limit" type="integer" label="32012" help="32013">
