msgctxt "#32001"
msgid "General"
msgstr "通用"

msgctxt "#32002"
msgid "Digit key input mode"
msgstr "数字键输入模式"

msgctxt "#32003"
msgid "In pure digit mode, keys input digits directly; in digit+letter mode, keys open a character selector with cycling selection."
msgstr "纯数字模式下按键直接输入数字；数字+字母模式下按键弹出字符选择器，连续按键循环或按方向键选择。"

msgctxt "#32004"
msgid "Digit + Letter"
msgstr "数字+字母"

msgctxt "#32005"
msgid "Pure Digit"
msgstr "纯数字"

msgctxt "#32006"
msgid "UI Style"
msgstr "界面风格"

msgctxt "#32007"
msgid "Automatically choose rounded or square based on skin, or set manually."
msgstr "自动根据皮肤选择圆角或方角，也可手动指定。"

msgctxt "#32008"
msgid "Auto"
msgstr "自动"

msgctxt "#32009"
msgid "Rounded"
msgstr "圆角"

msgctxt "#32010"
msgid "Square"
msgstr "方角"

msgctxt "#32011"
msgid "Set Global Background"
msgstr "设置全局背景"

msgctxt "#32012"
msgid "Filter result limit"
msgstr "筛选结果最大数量"

msgctxt "#32013"
msgid "Maximum number of items returned when browsing with filters."
msgstr "使用筛选浏览时返回的最大条目数。"

msgctxt "#32014"
msgid "Search result limit"
msgstr "搜索结果最大数量"

msgctxt "#32015"
msgid "Maximum number of items returned when searching."
msgstr "搜索时返回的最大条目数。"

msgctxt "#32016"
msgid "Enable movie set search"
msgstr "启用系列电影搜索"

msgctxt "#32017"
msgid "When enabled, movie sets can be searched by T9/initials. After toggling this option, enter 000000 (six zeros) in T9 input to manually rebuild or clean up the index."
msgstr "启用后可通过T9/首字母搜索系列电影,但是搜索索引会添加到系列电影介绍里，在某些皮肤上可能不太美观。切换开关后需要在T9输入000000（六个0）以手动清理或创建一次索引。"

msgctxt "#32018"
msgid "Search index field"
msgstr "搜索索引字段"

msgctxt "#32019"
msgid "Which database field to store and match the T9 search index. originaltitle is the default; sorttitle can be used as an alternative if originaltitle is needed for other purposes."
msgstr "用于存储和匹配T9搜索索引的数据库字段。默认使用originaltitle；如果originaltitle需要用于其他用途，可改用sorttitle。"

msgctxt "#32020"
msgid "originaltitle"
msgstr "originaltitle（原始标题）"

msgctxt "#32021"
msgid "sorttitle"
msgstr "sorttitle（排序标题）"

msgctxt "#32022"
msgid "Auto write search index"
msgstr "自动写入搜索索引"

msgctxt "#32023"
msgid "When enabled, the plugin will automatically write T9 search index data to the selected search field for movies and TV shows."
msgstr "启用后，插件会自动将T9搜索索引数据写入所选的搜索字段中（电影和剧集）。"

msgctxt "#32024"
msgid "Autofill/fix playlist for current episode or folder"
msgstr "播放时自动补全或修正当前播放剧集/文件夹内视频的播放列表"

msgctxt "#32025"
msgid "When enabled, starting an episode or a video file from a folder will automatically fill and sort the current playlist with the full season or all videos in that folder. For scraped TV shows, misplaced or out-of-order episodes are also corrected. Up to 50 items before and 50 after the current item are kept."
msgstr "启用后，开始播放剧集或文件夹中的视频文件时，自动将当前播放列表补全为整季剧集或该文件夹下全部视频，并修正已刷剥剧集的乱序问题；当前项前方保留最多50集，后方保留最多50集。"

msgctxt "#32026"
msgid "Media selector position"
msgstr "字幕/音轨选择器弹出位置"

msgctxt "#32027"
msgid "Set the screen position where the subtitle/audio selector appears"
msgstr "设置字幕和音轨选择器弹出的屏幕位置"

msgctxt "#32028"
msgid "Bottom right"
msgstr "右下角"

msgctxt "#32029"
msgid "Bottom left"
msgstr "左下角"

msgctxt "#32030"
msgid "Top right"
msgstr "右上角"

msgctxt "#32031"
msgid "Top left"
msgstr "左上角"

msgctxt "#32032"
msgid "Center"
msgstr "居中"

msgctxt "#32033"
msgid "Media selector background opacity"
msgstr "字幕/音轨选择器背景不透明度"

msgctxt "#32034"
msgid "Adjust subtitle/audio selector background opacity (0-100)."
msgstr "调整字幕/音轨选择器背景不透明度（0-100）。"
